{
  "title": "GEMINI-3 HIL REFERENCE TRANSLATIONS — THE DIAMOND ARM (1968)",
  "model": "gemini3",
  "items": [
    {
      "id": 1,
      "original": {
        "rus": "Ребята, на его месте должен был быть… я! — Напьёшься — будешь"
      },
      "segment_number": [
        642,
        643
      ]
    },
    {
      "id": 2,
      "original": {
        "rus": "Я не трус… но я боюсь"
      },
      "segment_number": [
        362,
        363
      ]
    },
    {
      "id": 3,
      "original": {
        "rus": "У Вас… ус… отклеился"
      },
      "segment_number": [
        1385
      ]
    },
    {
      "id": 4,
      "original": {
        "rus": "Леди, синьора, фрау, мисс, к сожалению, ничего не выйдет… Руссо туристо! Облико морале! Ферштейн?"
      },
      "segment_number": [
        109,
        110,
        111
      ]
    },
    {
      "id": 5,
      "original": {
        "rus": "Шеф, всё пропало, всё пропало! Гипс снимают, клиент уезжает…"
      },
      "segment_number": [
        1296,
        1297
      ]
    },
    {
      "id": 6,
      "original": {
        "rus": "Как говорит наш любимый шеф: «Если человек идиот, то это надолго»!"
      },
      "segment_number": [
        265,
        266,
        267
      ]
    },
    {
      "id": 7,
      "original": {
        "rus": "Дитя́м — мороженое, его бабе — цветы. Смотры, нэ пэрэпутай!.. Кутузоу!"
      },
      "segment_number": [
        528,
        529,
        530,
        531
      ]
    },
    {
      "id": 8,
      "original": {
        "rus": "Как говорит наш дорогой шеф, за чужой счёт пьют даже трезвенники… и язвенники!"
      },
      "segment_number": [
        738,
        739,
        740
      ]
    },
    {
      "id": 9,
      "original": {
        "rus": "Шампанское по утрам пьют или аристократы, или дегенераты"
      },
      "segment_number": [
        1020,
        1021
      ]
    },
    {
      "id": 10,
      "original": {
        "rus": "Достаточно одной таблэтки"
      },
      "segment_number": [
        1102
      ]
    },
    {
      "id": 11,
      "original": {
        "rus": "Наши люди в булочную на такси не ездят"
      },
      "segment_number": [
        674,
        675
      ]
    },
    {
      "id": 12,
      "original": {
        "rus": "Семё-он Семёныч!"
      },
      "segment_number": [
        404
      ]
    },
    {
      "id": 13,
      "original": {
        "rus": "Чтоб ты жил… на одну… зарплату!"
      },
      "segment_number": [
        484,
        485,
        486
      ]
    },
    {
      "id": 14,
      "original": {
        "rus": "Цигель-цигель, цигель, ай-лю-лю"
      },
      "segment_number": [
        101
      ]
    },
    {
      "id": 15,
      "original": {
        "rus": "Поскользнулся. Упал. Закрытый перелом. Потерял сознание. Очнулся — гипс"
      },
      "segment_number": [
        226,
        227,
        228,
        229
      ]
    },
    {
      "id": 16,
      "original": {
        "rus": "Лёгким движением руки брюки превращаются… Брюки превращаются… Превращаются брюки… В элегантные шорты"
      },
      "segment_number": [
        592,
        593,
        594,
        595,
        596
      ]
    },
    {
      "id": 17,
      "original": {
        "rus": "Не виноватая я! Он сам пришёл!"
      },
      "segment_number": [
        1240
      ]
    },
    {
      "id": 18,
      "original": {
        "rus": "Кто возьмёт билетов пачку, тот получит… — Водокачку!"
      },
      "segment_number": [
        745,
        746
      ]
    },
    {
      "id": 19,
      "original": {
        "rus": "А если не будут брать - отключим газ!"
      },
      "segment_number": [
        754
      ]
    },
    {
      "id": 20,
      "original": {
        "rus": "Ну, будете у нас на Колыме!.. — Нет, уж лучше Вы к нам!"
      },
      "segment_number": [
        891,
        893
      ]
    },
    {
      "id": 21,
      "original": {
        "rus": "В таком виде… я не могу. Мне нужно… сначала… принять вѫнну, выпить чашечку кофэ…"
      },
      "segment_number": [
        1025,
        1026,
        1027,
        1028,
        1029
      ]
    },
    {
      "id": 22,
      "original": {
        "rus": "— А у вас нет такого же, но с пелра… с перламутровыми пуговицами? — К сожалению, нет. — Нет? Будем искать…"
      },
      "segment_number": [
        1108,
        1109,
        1110,
        1111
      ]
    },
    {
      "id": 23,
      "original": {
        "rus": "Нет! На это я пойтить не могу!"
      },
      "segment_number": [
        1332
      ]
    }
  ]
}